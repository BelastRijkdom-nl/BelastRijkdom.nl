{
  "name": "BelastRijkdom.nl",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "stmux -n -M -- [ 'npm run watch' .. 'npm run build && npm run serve' ]",
    "serve": "http-server -o -c-1 ./dest/",
    "watch": "node -e \"const { watch } = require('./npm-scripts.js'); watch();\"",
    "build": "node -e \"const { build } = require('./npm-scripts.js'); build();\"",
    "postversion": "git push && git push --tags",
    "deploy": "npm version minor -m \"chore: Release version %s\" && npm run build && gh-pages -d dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BelastRijkdom-nl/BelastRijkdom.nl.git"
  },
  "homepage": "https://BelastRijkdom.nl/",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "chokidar": "^3.6.0",
    "gh-pages": "^6.3.0",
    "glob": "^11.0.3",
    "http-server": "^14.1.1",
    "nunjucks": "^3.2.4",
    "nunjucks-date-filter": "^0.1.1",
    "postcss": "^8.5.6",
    "postcss-cssnext": "^3.1.1",
    "postcss-import": "^16.1.1",
    "prettier": "^3.6.2",
    "shell": "^0.12.0",
    "shelljs": "^0.10.0",
    "stmux": "^1.8.11"
  },
  "prettier": {
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "importOrder": [
      "<THIRD_PARTY_MODULES>"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true
  }
}
